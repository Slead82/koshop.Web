@model OrderDetailViewModel
@{
    var o = Model.Order;
    ViewData["Title"] = "جزئیات سفارش";
    ViewData["ActiveNav"] = "";
    var statusLabel = new Dictionary<string, string> {
        {"Pending","در انتظار بررسی"}, {"Processing","در حال پردازش"}, {"Purchased","خریداری شده"},
        {"Shipped","ارسال شده"}, {"Done","تحویل شده"}, {"Cancelled","لغو شده"}
    };
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb"><a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><a href="/Orders/MyOrders">سفارشات من</a><span class="crumb-sep">›</span><span style="color:var(--orange)">@o.OrderCode</span></div>
    <h1>سفارش @o.OrderCode</h1>
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div style="max-width:var(--maxw);margin:16px auto 0;padding:0 32px">
    <div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:10px;padding:12px 16px;color:#15803d;font-weight:700">@TempData["Success"]</div>
  </div>
}

<div class="checkout-wrap">
  <div>
    <div class="admin-card">
      <div class="admin-card-head">
        <div><h2>اقلام سفارش</h2><div class="admin-card-sub">ثبت‌شده در @o.CreatedAt.ToString("yyyy/MM/dd")</div></div>
        <span class="badge badge-@o.Status.ToLower()">@statusLabel.GetValueOrDefault(o.Status, o.Status)</span>
      </div>
      @foreach (var item in o.Items)
      {
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--gray-line)">
          <span>@item.ProductNameSnapshot <span style="color:var(--ink-soft)">× @item.Quantity</span></span>
          <span>@((item.UnitPrice * item.Quantity).ToString("N0")) تومان</span>
        </div>
      }
      <div style="display:flex;justify-content:space-between;padding-top:16px;font-weight:800;font-size:15.5px">
        <span>مبلغ کل</span><span>@o.TotalAmount.ToString("N0") تومان</span>
      </div>
    </div>

    <div class="admin-card">
      <div class="admin-card-head"><h2>وضعیت سفارش</h2></div>
      <div class="admin-timeline">
        @foreach (var h in o.StatusHistory.OrderBy(x => x.ChangedAt))
        {
          <div class="admin-timeline-item done">
            <div class="admin-timeline-dot">@(h.Status == "Cancelled" ? "✕" : "✓")</div>
            <div class="admin-timeline-content"><strong>@statusLabel.GetValueOrDefault(h.Status, h.Status)</strong><span>@h.ChangedAt.ToString("yyyy/MM/dd HH:mm")</span></div>
          </div>
        }
      </div>
      @if (!string.IsNullOrEmpty(o.TrackingCode))
      {
        <p style="margin-top:14px;font-size:13px">کد رهگیری مرسوله: <strong>@o.TrackingCode</strong></p>
      }
    </div>
  </div>

  <div class="checkout-summary-card">
    <div class="cs-header">اطلاعات ارسال</div>
    <div style="padding:16px 20px;font-size:13.3px;color:var(--ink-soft);line-height:2">
      @if (!string.IsNullOrEmpty(o.ReceiverName))
      {
        <div><strong style="color:var(--ink)">گیرنده:</strong> @o.ReceiverName</div>
        <div><strong style="color:var(--ink)">تماس:</strong> @o.ReceiverPhone</div>
        <div><strong style="color:var(--ink)">آدرس:</strong> @o.ShippingAddress</div>
      }
      else
      {
        <span>این سفارش از طریق «ثبت سفارش کالا» ارسال شده و اطلاعات ارسال پس از تأیید نهایی تکمیل می‌شود.</span>
      }
    </div>
  </div>
</div>
