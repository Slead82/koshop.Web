@model TrackOrderViewModel
@{
    ViewData["Title"] = "پیگیری سفارش";
    ViewData["ActiveNav"] = "track-order";
    var statusLabel = new Dictionary<string, string> {
        {"Pending","در انتظار بررسی"}, {"Processing","در حال پردازش"}, {"Purchased","خریداری شده"},
        {"Shipped","ارسال شده"}, {"Done","تحویل شده"}, {"Cancelled","لغو شده"}
    };
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb"><a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><span style="color:var(--orange)">پیگیری سفارش</span></div>
    <h1>پیگیری سفارش</h1>
  </div>
</div>

<div class="track-page-wrap" style="max-width:640px;margin:32px auto;padding:0 20px">
  <div class="admin-card">
    <div class="admin-card-head"><h2>کد سفارش خود را وارد کنید</h2></div>
    <form asp-controller="Orders" asp-action="TrackResult" method="get" style="display:flex;gap:10px">
      <input type="text" name="orderCode" value="@Model.OrderCode" class="form-input" placeholder="مثلاً: KO-1042" style="flex:1">
      <button type="submit" class="btn-cta">جستجو</button>
    </form>
  </div>

  @if (Model.Searched)
  {
    if (Model.FoundOrder == null)
    {
      <div class="admin-card" style="margin-top:16px;text-align:center;color:var(--ink-soft)">سفارشی با این کد پیدا نشد. کد سفارش را بررسی کنید.</div>
    }
    else
    {
      var o = Model.FoundOrder;
      <div class="admin-card" style="margin-top:16px">
        <div class="admin-card-head">
          <div><h2>@o.OrderCode</h2><div class="admin-card-sub">ثبت‌شده در @o.CreatedAt.ToString("yyyy/MM/dd")</div></div>
          <span class="badge badge-@o.Status.ToLower()">@statusLabel.GetValueOrDefault(o.Status, o.Status)</span>
        </div>
        <div class="admin-timeline">
          @foreach (var h in o.StatusHistory.OrderBy(x => x.ChangedAt))
          {
            <div class="admin-timeline-item done">
              <div class="admin-timeline-dot">@(h.Status == "Cancelled" ? "✕" : "✓")</div>
              <div class="admin-timeline-content"><strong>@statusLabel.GetValueOrDefault(h.Status, h.Status)</strong><span>@h.ChangedAt.ToString("yyyy/MM/dd HH:mm")</span></div>
            </div>
          }
        </div>
        @if (!string.IsNullOrEmpty(o.TrackingCode))
        {
          <p style="margin-top:14px;font-size:13px">کد رهگیری مرسوله: <strong>@o.TrackingCode</strong></p>
        }
      </div>
    }
  }
</div>
