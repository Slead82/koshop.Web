@model CheckoutViewModel
@{
    ViewData["Title"] = "تسویه‌حساب";
    ViewData["ActiveNav"] = "";
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb"><a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><a href="/Cart">سبد خرید</a><span class="crumb-sep">›</span><span style="color:var(--orange)">تسویه‌حساب</span></div>
    <h1>تسویه‌حساب</h1>
  </div>
</div>

<div class="checkout-wrap">
  <div>
    <div class="admin-card">
      <div class="admin-card-head"><h2>اطلاعات گیرنده</h2></div>
      <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" id="checkout-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color:#e1452f;font-size:13px;margin-bottom:12px"></div>

        <div class="admin-form-group">
          <label asp-for="ReceiverName"></label>
          <input asp-for="ReceiverName" class="form-input">
          <span asp-validation-for="ReceiverName" style="color:#e1452f;font-size:12px"></span>
        </div>
        <div class="admin-form-group">
          <label asp-for="ReceiverPhone"></label>
          <input asp-for="ReceiverPhone" class="form-input">
          <span asp-validation-for="ReceiverPhone" style="color:#e1452f;font-size:12px"></span>
        </div>
        <div class="admin-form-group">
          <label asp-for="ShippingAddress"></label>
          <textarea asp-for="ShippingAddress" class="admin-textarea" style="min-height:90px"></textarea>
          <span asp-validation-for="ShippingAddress" style="color:#e1452f;font-size:12px"></span>
        </div>
      </form>
    </div>
  </div>

  <div class="checkout-summary-card">
    <div class="cs-header">خلاصه سفارش</div>
    <div class="checkout-product-list">
      @foreach (var line in Model.Lines)
      {
        <div class="cpl-item">
          <div class="cpl-img"><img src="@line.ImageUrl" alt="@line.Name"></div>
          <div>
            <div class="cpl-name">@line.Name</div>
            <div class="cpl-meta">تعداد: @line.Quantity — @line.LineTotal.ToString("N0") تومان</div>
          </div>
        </div>
      }
    </div>
    <div style="padding:16px 20px;border-top:1px solid var(--gray-line)">
      <div style="display:flex;justify-content:space-between;font-size:13.3px;margin-bottom:8px;color:var(--ink-soft)"><span>جمع کالاها</span><span>@Model.Subtotal.ToString("N0") تومان</span></div>
      <div style="display:flex;justify-content:space-between;font-size:13.3px;margin-bottom:12px;color:var(--ink-soft)"><span>هزینه ارسال</span><span>@Model.ShippingCost.ToString("N0") تومان</span></div>
      <div style="display:flex;justify-content:space-between;font-size:15.5px;font-weight:800;margin-bottom:16px;padding-top:10px;border-top:1px solid var(--gray-line)"><span>مبلغ نهایی</span><span>@Model.Total.ToString("N0") تومان</span></div>
      <button type="submit" form="checkout-form" class="btn-cta" style="width:100%;justify-content:center">ثبت نهایی سفارش</button>
      <p style="font-size:11px;color:var(--ink-soft);margin-top:10px;text-align:center">درگاه پرداخت آنلاین به‌زودی اضافه می‌شود؛ فعلاً سفارش با وضعیت «در انتظار بررسی» ثبت می‌شود.</p>
    </div>
  </div>
</div>
