@model AdminProductFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "ویرایش محصول" : "افزودن محصول جدید";
    Layout = "_AdminLayout";
}

<div style="margin-bottom:16px">
  <a href="/AdminProducts" class="btn-admin-outline">بازگشت به لیست محصولات</a>
</div>

<div class="admin-card" style="max-width:640px">
  <div class="admin-card-head"><h2>@ViewData["Title"]</h2></div>

  <form asp-controller="AdminProducts" asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" style="color:#e1452f;font-size:13px;margin-bottom:12px"></div>

    <div class="admin-form-group">
      <label asp-for="Name">نام محصول</label>
      <input asp-for="Name" class="admin-input" placeholder="مثلاً: کیف دستی چرم">
      <span asp-validation-for="Name" style="color:#e1452f;font-size:12px"></span>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label asp-for="CategoryId">دسته‌بندی</label>
        <select asp-for="CategoryId" class="admin-select">
          @foreach (var c in Model.Categories)
          {
            <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
          }
        </select>
      </div>
      <div class="admin-form-group">
        <label asp-for="Price">قیمت (تومان)</label>
        <input asp-for="Price" type="number" class="admin-input" placeholder="۰">
        <span asp-validation-for="Price" style="color:#e1452f;font-size:12px"></span>
      </div>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label asp-for="OldPrice">قیمت قبل از تخفیف (اختیاری)</label>
        <input asp-for="OldPrice" type="number" class="admin-input" placeholder="خالی بگذارید اگر تخفیف ندارد">
      </div>
      <div class="admin-form-group">
        <label asp-for="Stock">موجودی انبار</label>
        <input asp-for="Stock" type="number" class="admin-input" placeholder="۰">
      </div>
    </div>

    <div class="admin-form-group">
      <label asp-for="Brand">برند (اختیاری)</label>
      <input asp-for="Brand" class="admin-input" placeholder="مثلاً: Xiaomi">
    </div>

    <div class="admin-form-group">
      <label asp-for="Description">توضیحات</label>
      <textarea asp-for="Description" class="admin-textarea" placeholder="توضیحات محصول..."></textarea>
    </div>

    <div class="admin-form-group">
      <label asp-for="ImageUrl">آدرس تصویر محصول</label>
      <input asp-for="ImageUrl" class="admin-input" placeholder="/assets/products/p001.svg">
      <div class="hint">فعلاً فقط آدرس/مسیر تصویر — آپلود مستقیم فایل در قدم‌های بعدی اضافه می‌شود.</div>
    </div>

    <div class="admin-form-group">
      <label asp-for="Status">وضعیت</label>
      <select asp-for="Status" class="admin-select">
        <option value="Active" selected="@(Model.Status == "Active")">فعال</option>
        <option value="Draft" selected="@(Model.Status == "Draft")">پیش‌نویس</option>
      </select>
    </div>

    <button type="submit" class="btn-cta" style="width:100%;justify-content:center;margin-top:10px">ذخیره محصول</button>
  </form>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
