@model CartIndexViewModel
@{
    ViewData["Title"] = "سبد خرید";
    ViewData["ActiveNav"] = "";
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb"><a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><span style="color:var(--orange)">سبد خرید</span></div>
    <h1>سبد خرید</h1>
  </div>
</div>

@if (TempData["CartSuccess"] != null)
{
  <div style="max-width:var(--maxw);margin:16px auto 0;padding:0 32px">
    <div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:10px;padding:12px 16px;color:#15803d;font-weight:700">@TempData["CartSuccess"]</div>
  </div>
}

<div class="cart-page-wrap">
  @if (!Model.Lines.Any())
  {
    <div class="cart-items-card" style="text-align:center;padding:60px 20px">
      <strong style="display:block;font-size:16px;margin-bottom:8px">سبد خرید شما خالی است</strong>
      <p style="color:var(--ink-soft);margin-bottom:20px">محصولی به سبد خرید خود اضافه نکرده‌اید.</p>
      <a href="/Shop" class="btn-cta">رفتن به فروشگاه</a>
    </div>
  }
  else
  {
    <div class="cart-items-card">
      @foreach (var line in Model.Lines)
      {
        <div class="cart-item">
          <div class="cart-item-check"></div>
          <div class="cart-item-img"><img src="@line.ImageUrl" alt="@line.Name"></div>
          <div>
            <div class="cart-item-name">@line.Name</div>
            <div class="cart-item-meta">
              @if (line.Stock <= 0)
              {
                <span style="color:#e1452f;font-weight:700">ناموجود</span>
              }
              else
              {
                @:موجودی: @line.Stock عدد
              }
            </div>
          </div>
          <div class="cart-item-right">
            <strong>@line.LineTotal.ToString("N0") تومان</strong>
            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" style="display:flex;align-items:center;gap:6px">
              @Html.AntiForgeryToken()
              <input type="hidden" name="productId" value="@line.ProductId" />
              <input type="number" name="quantity" value="@line.Quantity" min="1" max="@line.Stock" style="width:56px;text-align:center;border:1px solid var(--gray-line);border-radius:8px;padding:4px" onchange="this.form.submit()">
            </form>
            <form asp-controller="Cart" asp-action="Remove" method="post">
              @Html.AntiForgeryToken()
              <input type="hidden" name="productId" value="@line.ProductId" />
              <button type="submit" style="background:none;border:none;color:#e1452f;font-size:12px;cursor:pointer;font-family:inherit">حذف</button>
            </form>
          </div>
        </div>
      }
    </div>

    <div class="cart-summary-card">
      <h3 style="font-size:15px;font-weight:800;margin-bottom:16px">جمع سبد خرید</h3>
      <div style="display:flex;justify-content:space-between;font-size:13.3px;margin-bottom:10px;color:var(--ink-soft)">
        <span>جمع کالاها</span><span>@Model.Subtotal.ToString("N0") تومان</span>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:15.5px;font-weight:800;margin-bottom:18px;padding-top:10px;border-top:1px solid var(--gray-line)">
        <span>مبلغ قابل پرداخت</span><span>@Model.Subtotal.ToString("N0") تومان</span>
      </div>
      <a href="/Checkout" class="btn-cta" style="width:100%;justify-content:center">ادامه فرآیند خرید</a>

      <div class="cart-taobao-cta">
        <h4>محصول مدنظرتون رو پیدا نکردید؟</h4>
        <p>می‌تونید مستقیم از فروشگاه‌های مرجع (Taobao, 1688, Tmall) برامون سفارش ثبت کنید.</p>
        <a href="/Orders/Submit" class="btn-admin-outline" style="width:100%;justify-content:center;display:flex">ثبت سفارش کالا</a>
      </div>
    </div>
  }
</div>
