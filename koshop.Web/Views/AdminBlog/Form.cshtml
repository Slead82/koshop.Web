@model AdminBlogFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "ویرایش مقاله" : "نوشتن مقاله جدید";
    Layout = "_AdminLayout";
}

<div class="admin-card" style="max-width:680px">
  <div class="admin-card-head"><h2>@ViewData["Title"]</h2></div>

  <form asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" style="color:#e1452f;font-size:13px;margin-bottom:12px"></div>

    <div class="admin-form-group">
      <label asp-for="Title">عنوان مقاله</label>
      <input asp-for="Title" class="admin-input" placeholder="عنوان مقاله را وارد کنید">
      <span asp-validation-for="Title" style="color:#e1452f;font-size:12px"></span>
    </div>

    <div class="admin-form-group">
      <label asp-for="Summary">خلاصه مقاله</label>
      <textarea asp-for="Summary" class="admin-textarea" style="min-height:70px" placeholder="خلاصه کوتاهی از مقاله بنویسید..."></textarea>
    </div>

    <div class="admin-form-group">
      <label asp-for="Body">متن کامل مقاله</label>
      <textarea asp-for="Body" class="admin-textarea" style="min-height:220px" placeholder="متن کامل مقاله..."></textarea>
      <span asp-validation-for="Body" style="color:#e1452f;font-size:12px"></span>
    </div>

    <div class="admin-form-group">
      <label asp-for="CoverImageUrl">آدرس تصویر شاخص</label>
      <input asp-for="CoverImageUrl" class="admin-input" placeholder="/assets/blog/cover1.jpg">
    </div>

    <div style="display:flex;gap:10px;margin-top:16px">
      <button type="submit" name="action" value="publish" class="btn-cta">انتشار</button>
      <button type="submit" name="action" value="draft" class="btn-admin-outline">ذخیره پیش‌نویس</button>
      <a href="/AdminBlog" class="btn-admin-outline">انصراف</a>
    </div>
  </form>
</div>
