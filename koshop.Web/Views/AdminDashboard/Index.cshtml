@model AdminDashboardViewModel
@{
    ViewData["Title"] = "داشبورد";
    Layout = "_AdminLayout";
    var statusLabel = new Dictionary<string, string> {
        {"Pending","در انتظار بررسی"}, {"Processing","در حال پردازش"}, {"Purchased","خریداری شده"},
        {"Shipped","ارسال شده"}, {"Done","تحویل شده"}, {"Cancelled","لغو شده"}
    };
}

<div class="admin-stat-grid">
  <div class="admin-stat-card">
    <div class="admin-stat-top">
      <div class="admin-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3.2" stroke="currentColor" stroke-width="1.6"/><path d="M2.8 19c1.2-3.3 3.6-5 6.2-5s5 1.7 6.2 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
    </div>
    <div class="admin-stat-value">@Model.TotalUsers.ToString("N0")</div>
    <div class="admin-stat-label">کاربران فعال</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-top">
      <div class="admin-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" stroke="currentColor" stroke-width="1.6"/></svg></div>
    </div>
    <div class="admin-stat-value">@Model.TotalOrders.ToString("N0")</div>
    <div class="admin-stat-label">کل سفارشات</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-top">
      <div class="admin-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
    </div>
    <div class="admin-stat-value">@Model.TotalRevenue.ToString("N0")</div>
    <div class="admin-stat-label">کل درآمد (تومان)</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-top">
      <div class="admin-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="m12 2.5 3 6.3 6.8.9-5 4.9 1.2 6.9L12 18l-6 3.5 1.2-6.9-5-4.9 6.8-.9Z" stroke="currentColor" stroke-width="1.6"/></svg></div>
    </div>
    <div class="admin-stat-value">@Model.PendingReviews.ToString("N0")</div>
    <div class="admin-stat-label">نظرات در انتظار بررسی</div>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-head">
    <div><h2>آخرین سفارشات</h2><div class="admin-card-sub">نازه‌ترین سفارش‌های ثبت‌شده در فروشگاه</div></div>
    <a href="/AdminOrders" class="btn-admin-outline">مشاهده همه</a>
  </div>
  @if (!Model.RecentOrders.Any())
  {
    <div class="admin-empty"><strong>هنوز سفارشی ثبت نشده</strong><span>سفارشات جدید اینجا نمایش داده می‌شوند.</span></div>
  }
  else
  {
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>شناسه</th><th>مشتری</th><th>مبلغ</th><th>وضعیت</th></tr></thead>
        <tbody>
          @foreach (var o in Model.RecentOrders)
          {
            <tr>
              <td class="cell-main">@o.OrderCode</td>
              <td>@(o.User?.FullName ?? "—")</td>
              <td>@o.TotalAmount.ToString("N0")</td>
              <td><span class="badge badge-@o.Status.ToLower()">@statusLabel.GetValueOrDefault(o.Status, o.Status)</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

<div class="admin-card">
  <div class="admin-card-head"><h2>تیکت‌های باز</h2></div>
  <p style="font-size:13.5px;color:var(--ink-soft)">در حال حاضر <strong style="color:var(--ink)">@Model.OpenTickets</strong> تیکت پشتیبانی باز وجود دارد.</p>
</div>
