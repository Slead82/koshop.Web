@model AboutPageContent
@{
    ViewData["Title"] = !string.IsNullOrWhiteSpace(Model.SeoTitle) ? Model.SeoTitle : "درباره ما";
    ViewData["ActiveNav"] = "about";
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb reveal-from-right"><a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><span style="color:var(--orange)">درباره ما</span></div>
  </div>
</div>

<div class="about-hero">
  <div class="about-hero-inner">
    <div class="about-hero-img reveal-from-right">
      <div style="width:100%;height:100%;background:var(--dark-card);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;min-height:280px;padding:40px;">
        <img src="/assets/ko-logo.png" alt="KO" style="width:80%;max-width:300px;object-fit:contain;filter:brightness(0) invert(1)">
      </div>
    </div>
    <div class="about-hero-text reveal-from-left">
      <div class="about-hero-eyebrow">ما که هستیم؟</div>
      @if (!string.IsNullOrWhiteSpace(Model.HeaderTitle))
      {
        <h1>@Model.HeaderTitle</h1>
      }
      else
      {
        <h1>درباره <span>ما</span></h1>
      }
      <p>@(Model.Text_Body ?? "KO با هدف ایجاد تجربه سریع و مطمئن برای خرید از فروشگاه‌های مرجع راه‌اندازی شده است. ما به شما کمک می‌کنیم تا کالاهای مورد نظرتان را از چین تهیه کرده و در کوتاه‌ترین زمان ممکن، درب منزل تحویل بگیرید.")</p>
      <div class="about-stats">
        <div class="about-stat"><div class="about-stat-val" data-count-up="98">98%</div><div class="about-stat-label">رضایت مشتریان</div></div>
        <div class="about-stat"><div class="about-stat-val" data-count-up="50000">50K+</div><div class="about-stat-label">سفارش موفق</div></div>
        <div class="about-stat"><div class="about-stat-val" data-count-up="20000">20K+</div><div class="about-stat-label">مشتریان فعال</div></div>
      </div>
    </div>
  </div>
</div>

<div class="about-section">
  <div style="text-align:center;margin-bottom:32px" class="reveal-from-bottom">
    <p style="font-size:13px;font-weight:700;color:var(--orange);margin-bottom:8px">چرا KO ؟</p>
    <h2 style="font-size:26px;font-weight:800">@(Model.Box1_Title ?? "مزیت‌های ما")</h2>
  </div>
  <div class="about-features-grid">
    <div class="about-feature-card reveal-from-bottom"><div class="afc-icon"><svg viewBox="0 0 24 24" fill="none" width="24" height="24"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" stroke="currentColor" stroke-width="1.5"/><path d="M4 7l8 4 8-4M12 11v10" stroke="currentColor" stroke-width="1.4"/></svg></div><div class="afc-title">خرید مطمئن از فروشگاه‌های مرجع</div><div class="afc-desc">با خیال راحت از فروشگاه معتبر چینی با کیفیت بالا خرید کنید</div></div>
    <div class="about-feature-card reveal-from-bottom delay-1"><div class="afc-icon"><svg viewBox="0 0 24 24" fill="none" width="24" height="24"><path d="M4 13v-1a8 8 0 0 1 16 0v1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="13" width="4" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg></div><div class="afc-title">پشتیبانی ۲۴/۷</div><div class="afc-desc">تیم پشتیبانی ما در تمام ساعات روز در دسترس و پاسخگوی شماست</div></div>
    <div class="about-feature-card reveal-from-bottom delay-2"><div class="afc-icon"><svg viewBox="0 0 24 24" fill="none" width="24" height="24"><rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M16 3h-8l-2 4h12l-2-4Z" stroke="currentColor" stroke-width="1.4"/></svg></div><div class="afc-title">ارسال سریع</div><div class="afc-desc">سفارش‌ها شما در سریع‌ترین زمان ممکن به دستانتان می‌رسد</div></div>
    <div class="about-feature-card reveal-from-bottom delay-2"><div class="afc-icon"><svg viewBox="0 0 24 24" fill="none" width="24" height="24"><rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 10h18" stroke="currentColor" stroke-width="1.4"/></svg></div><div class="afc-title">پرداخت امن</div><div class="afc-desc">اطلاعات و پرداخت‌های شما با بالاترین سطح امنیت انجام می‌شود</div></div>
    <div class="about-feature-card reveal-from-bottom delay-3"><div class="afc-icon"><svg viewBox="0 0 24 24" fill="none" width="24" height="24"><path d="M12 3.5 19 6v5.5c0 4.6-3 7.9-7 9-4-1.1-7-4.4-7-9V6l7-2.5Z" stroke="currentColor" stroke-width="1.5"/></svg></div><div class="afc-title">کارمزد منصفانه</div><div class="afc-desc">با حداقل کارمزد و شفافیت کامل در هزینه‌ها خرید کنید</div></div>
  </div>
</div>

<div class="about-section" style="background:#fff;border-top:1px solid var(--gray-line);border-bottom:1px solid var(--gray-line)">
  <div class="about-team-grid">
    <div class="about-team-img reveal-from-right">
      <div style="width:100%;height:100%;min-height:260px;background:var(--gray-bg);display:flex;align-items:center;justify-content:center">
        <svg viewBox="0 0 24 24" fill="none" width="80" height="80" style="color:#c0c2cb"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.2"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.2"/></svg>
      </div>
    </div>
    <div class="about-team-text reveal-from-left">
      <h2>@(Model.Box2_Title ?? "تیم ما")</h2>
      <p>تیم ما متشکل از افرادی جوان، متخصص و پرانرژی است که با اشتیاق فراوان برای ارائه بهترین خدمات به شما تلاش می‌کنند. هدف ما، جلب اعتماد شما و ساختن تجربه‌ای بی‌نقص از خرید بین‌المللی است.</p>
      <button class="btn-team-more" onclick="window.location.href='/Home/Contact'">با تیم ما بیشتر آشنا شوید ←</button>
    </div>
  </div>
</div>

<div class="about-section">
  <div class="about-commitment reveal-from-bottom">
    <div class="ac-icon"><svg viewBox="0 0 24 24" fill="none" width="28" height="28"><path d="M12 3.5 19 6v5.5c0 4.6-3 7.9-7 9-4-1.1-7-4.4-7-9V6l7-2.5Z" stroke="currentColor" stroke-width="1.5"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
    <h3>@(Model.Box3_Title ?? "تعهد ما")</h3>
    <p>@(Model.Box3_Text ?? "ما در KO متعهد به ارائه خدمات با کیفیت، شفافیت در هزینه‌ها و احترام به مشتریان هستیم. رضایت شما، اولویت و مهم‌ترین هدف ماست.")</p>
    <div class="about-commitment-sig">KO Team<br><span style="font-size:13px;font-weight:500;color:var(--ink-soft)">تیم مدیریت KO</span></div>
  </div>
</div>

<section class="feature-strip reveal-from-bottom">
  <div class="feature-strip-inner" id="features-top"></div>
</section>
