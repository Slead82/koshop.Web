@{
    var activeNav = ViewData["ActiveNav"] as string ?? "";
    bool isAuthed = User.Identity?.IsAuthenticated == true;
    bool isAdmin = User.IsInRole("Admin");
    string displayName = isAuthed ? (User.Identity?.Name ?? "کاربر") : "";
    string displayRole = isAuthed ? (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "کاربر عادی") : "";
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#f4790a">
<link rel="icon" type="image/png" sizes="32x32" href="~/assets/favicon-32.png">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/style.css">
<link rel="stylesheet" href="~/animations.css">
<link rel="stylesheet" href="~/pages.css">
<title>@ViewData["Title"] - KO Shop</title>
</head>
<body>
<script src="~/ko-store.js"></script>

<div class="page-transition-overlay"><div class="ptl-logo"><img src="~/assets/ko-logo.png" alt="KO" style="width:80px;filter:brightness(0) invert(1)"></div></div>

<!-- ===================== HEADER ===================== -->
<header class="site-header reveal-from-top">
  <div class="header-inner">
    <a class="logo" href="/"><img src="~/assets/ko-logo.png" alt="KO" class="header-logo-img"></a>
    <button class="hamburger-btn" aria-label="منو" onclick="openMobileNav()">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav">
      <a href="/" class="@(activeNav == "home" ? "active" : "")">صفحه اصلی</a>
      <a href="/Shop" class="@(activeNav == "shop" ? "active" : "")">فروشگاه</a>
      <a href="/Orders/Submit" class="@(activeNav == "submit-order" ? "active" : "")">ثبت سفارش KO</a>
      <a href="/Orders/Track" class="@(activeNav == "track-order" ? "active" : "")">پیگیری سفارش</a>
      <a href="/Home/About" class="@(activeNav == "about" ? "active" : "")">درباره ما</a>
      <a href="/Blog" class="@(activeNav == "blog" ? "active" : "")">مقالات</a>
      <a href="/Home/Terms" class="@(activeNav == "terms" ? "active" : "")">قوانین و مقررات</a>
      <a href="/Home/Contact" class="@(activeNav == "contact" ? "active" : "")">تماس با ما</a>
    </nav>
    <div class="header-actions">
      <button class="btn-cta-small" onclick="window.location.href='/Orders/Submit'"><span class="plus-icon">+</span>ثبت سفارش کالا</button>
      <button class="icon-btn" onclick="window.location.href='/Shop/Search'">
        <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      </button>
      <button class="icon-btn cart-btn" onclick="window.location.href='/Cart'">
        <svg viewBox="0 0 24 24" fill="none"><path d="M2 3h2l2.4 12.2a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.6L21 7H6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="20" r="1.4" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="20" r="1.4" stroke="currentColor" stroke-width="1.5"/></svg>
        <span class="cart-badge">0</span>
      </button>

      @if (!isAuthed)
      {
        <div class="header-auth-guest" style="display:flex">
          <a href="/Account/Login" class="btn-auth-header-ghost">ورود</a>
          <a href="/Account/Register" class="btn-auth-header-fill">عضویت</a>
        </div>
      }
      else
      {
        <div class="header-auth-user" style="display:flex">
          <div class="header-user-dropdown" id="header-user-dropdown">
            <button class="icon-btn header-user-btn" id="header-user-btn" aria-label="حساب کاربری" onclick="toggleUserDropdown()">
              <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.6"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            </button>
            <div class="user-dropdown-menu" id="user-dropdown-menu">
              <div class="udm-header">
                <div class="udm-avatar"><svg viewBox="0 0 24 24" fill="none" width="26" height="26"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.5"/></svg></div>
                <div><strong>@displayName</strong><span>@displayRole</span></div>
              </div>
              @if (isAdmin)
              {
                <a href="/AdminDashboard">
                  <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>داشبورد
                </a>
              }
              <a href="/Orders/MyOrders"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" stroke="currentColor" stroke-width="1.5"/></svg>سفارشات من</a>
              <a href="/Account/Settings"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.5"/></svg>تنظیمات حساب</a>
              <a href="/Orders/Track"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>پیگیری سفارش</a>
              <div class="udm-divider"></div>
              <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="udm-logout" style="background:none;border:none;width:100%;text-align:inherit;cursor:pointer;font-family:inherit">
                  <svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>خروج از حساب
                </button>
              </form>
            </div>
          </div>
        </div>
      }
    </div>
  </div>
</header>

<!-- ===================== PAGE CONTENT ===================== -->
@RenderBody()

<!-- ===================== FOOTER ===================== -->
@if (!isAuthed)
{
  <footer class="site-footer">
    <div class="newsletter">
      <div class="newsletter-cart">
        <div class="hero-glow small"></div>
        <img src="~/assets/ko-logo.png" alt="KO Logo" class="newsletter-cart-img" style="object-fit:contain;padding:10px;">
      </div>
      <div class="newsletter-content">
        <h3>از جدیدترین محصولات و تخفیف‌ها باخبر شوید!</h3>
        <p>ایمیل خود را وارد کنید تا از آخرین تخفیف‌ها و جدیدترین محصولات ویژه مطلع شوید.</p>
        <form class="newsletter-form" onsubmit="if(this.querySelector('input').value){showToast('عضویت شما ثبت شد!', 'success');}else{showToast('ایمیل خود را وارد کنید', 'error');}return false;">
          <button type="submit" class="btn-cta">عضویت</button>
          <input type="email" placeholder="ایمیل شما">
        </form>
      </div>
      <div class="newsletter-brand">
        <a class="logo footer-logo" href="/"><img src="~/assets/ko-logo.png" alt="KO" style="width:80px;filter:brightness(0) invert(1)"></a>
        <p>مرجع کامل مطمئن برای خرید محصولات از تمامی فروشگاه ها و ارسال سریع به سراسر ایران.</p>
        <div class="social-icons">
          <a href="#" aria-label="تلگرام"><svg viewBox="0 0 24 24" fill="none"><path d="m21 4-19 8 6 2m13-10-3.5 16-9.5-6m13-10L7.5 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a href="#" aria-label="اینستاگرام"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
          <a href="#" aria-label="واتساپ"><svg viewBox="0 0 24 24" fill="none"><path d="M20 12a8 8 0 1 1-3.8-6.8L20 4l-1 3.5A7.96 7.96 0 0 1 20 12Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 9.5c0 3 2.5 5.5 5.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-links">
        <a href="/Home/Faq">سوالات متداول</a>
        <a href="/Blog">مقالات</a>
        <a href="/Home/Terms">قوانین و مقررات</a>
        <a href="/Home/Privacy">حریم خصوصی</a>
        <a href="/Home/Contact">تماس با ما</a>
        <a href="/Home/About">درباره ما</a>
      </div>
      <p class="copyright">تمامی حقوق این سایت محفوظ است.</p>
    </div>
  </footer>
}
else
{
  <footer class="site-footer site-footer-ext">
    <div class="footer-ext-grid">
      <div class="footer-ext-brand">
        <a class="logo footer-logo" href="/"><img src="~/assets/ko-logo.png" alt="KO" style="width:80px;filter:brightness(0) invert(1)"></a>
        <p>سفارش هر کالای خارجی دلخواه شما از سایت‌های بین‌المللی</p>
        <div class="social-icons">
          <a href="#"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
          <a href="#"><svg viewBox="0 0 24 24" fill="none"><path d="m21 4-19 8 6 2m13-10-3.5 16-9.5-6m13-10L7.5 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a href="#"><svg viewBox="0 0 24 24" fill="none"><path d="M20 12a8 8 0 1 1-3.8-6.8L20 4l-1 3.5A7.96 7.96 0 0 1 20 12Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
      <div class="footer-ext-col">
        <h4>دسترسی سریع</h4>
        <a href="/">صفحه اصلی</a>
        <a href="/Shop">فروشگاه</a>
        <a href="/Blog">مقالات</a>
        <a href="/Home/About">درباره ما</a>
        <a href="/Home/Contact">تماس با ما</a>
      </div>
      <div class="footer-ext-col">
        <h4>دسته‌بندی‌ها</h4>
        <a href="/Shop/Category">کالای دیجیتال</a>
        <a href="/Shop/Category">مد و پوشاک</a>
        <a href="/Shop/Category">زیبایی و سلامت</a>
        <a href="/Shop/Category">اکسسوری</a>
      </div>
      <div class="footer-ext-col">
        <h4>خدمات مشتریان</h4>
        <a href="/Orders/Track">پیگیری سفارش</a>
        <a href="/Home/Faq">سوالات متداول</a>
        <a href="/Home/Terms">قوانین و مقررات</a>
        <a href="/Home/Privacy">حریم خصوصی</a>
        <a href="/Home/Contact">تماس با ما</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-links">
        <a href="/Home/Faq">سوالات متداول</a>
        <a href="/Home/Terms">قوانین و مقررات</a>
        <a href="/Home/Contact">تماس با ما</a>
        <a href="/Home/About">درباره ما</a>
      </div>
      <p class="copyright">تمامی حقوق این سایت محفوظ است.</p>
    </div>
  </footer>
}

<!-- MOBILE NAV -->
<div class="mobile-nav-overlay" id="mobile-overlay" onclick="closeMobileNav()"></div>
<div class="mobile-nav-drawer" id="mobile-drawer">
  <div class="mobile-nav-header">
    <a href="/"><img src="~/assets/ko-logo.png" alt="KO" style="height:36px;object-fit:contain"></a>
    <button class="mobile-nav-close" onclick="closeMobileNav()">✕</button>
  </div>
  <div class="mobile-nav-links">
    <a href="/"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="1.5"/><polyline points="9 22 9 12 15 12 15 22" stroke="currentColor" stroke-width="1.5"/></svg>صفحه اصلی</a>
    <a href="/Shop"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M2 3h2l2.4 12.2a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.6L21 7H6" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="20" r="1.3" fill="currentColor"/><circle cx="17" cy="20" r="1.3" fill="currentColor"/></svg>فروشگاه</a>
    <a href="/Orders/Submit"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>ثبت سفارش KO</a>
    <a href="/Orders/Track"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>پیگیری سفارش</a>
    <a href="/Home/About"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>درباره ما</a>
    <a href="/Home/Terms"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M7 3.5h7l4 4V20a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4.5a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.5"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>قوانین و مقررات</a>
    <a href="/Home/Faq"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>سوالات متداول</a>
    <a href="/Home/Contact"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="m2 7 10 7 10-7" stroke="currentColor" stroke-width="1.4"/></svg>تماس با ما</a>
  </div>
  <div class="mobile-nav-footer">
    @if (!isAuthed)
    {
      <a href="/Account/Login" class="btn-auth-header-ghost" style="text-align:center;padding:12px">ورود به حساب</a>
      <a href="/Account/Register" class="btn-auth-header-fill" style="text-align:center;padding:12px">ثبت‌نام رایگان</a>
    }
    else
    {
      <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-auth-header-fill" style="width:100%;text-align:center;padding:12px;border:none;font-family:inherit;cursor:pointer">خروج از حساب</button>
      </form>
    }
  </div>
</div>

<script>
function openMobileNav(){
  document.getElementById('mobile-drawer').classList.add('open');
  document.getElementById('mobile-overlay').style.display='block';
  setTimeout(()=>document.getElementById('mobile-overlay').classList.add('open'),10);
  document.body.style.overflow='hidden';
  document.querySelector('.hamburger-btn')?.classList.add('open');
}
function closeMobileNav(){
  document.getElementById('mobile-drawer').classList.remove('open');
  document.getElementById('mobile-overlay').classList.remove('open');
  setTimeout(()=>{document.getElementById('mobile-overlay').style.display='none';},280);
  document.body.style.overflow='';
  document.querySelector('.hamburger-btn')?.classList.remove('open');
}
</script>
<script src="~/script.js"></script>
<script src="~/animations.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
