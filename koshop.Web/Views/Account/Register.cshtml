@model RegisterViewModel
@{
    ViewData["Title"] = "ثبت‌نام";
    ViewData["ActiveNav"] = "";
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb reveal-from-right">
      <a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><span style="color:var(--orange)">ثبت‌نام</span>
    </div>
  </div>
</div>

<div class="auth-page-layout">
  <div class="auth-form-panel reveal-from-right">
    <div class="auth-form-box">
      <h1 class="auth-title">ثبت‌نام در KO</h1>
      <div class="auth-title-line"></div>
      <p class="auth-sub">با ساختن حساب کاربری، از خدمات ویژه و تجربه خرید آسان KO لذت ببرید.</p>

      <form asp-controller="Account" asp-action="Register" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color:#e1452f;font-size:13px;margin-bottom:12px"></div>

        <div class="form-group">
          <label asp-for="FullName"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <input asp-for="FullName" class="form-input" placeholder="نام و نام خانوادگی خود را وارد کنید" />
          </div>
          <span asp-validation-for="FullName" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group">
          <label asp-for="Username"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <input asp-for="Username" class="form-input" placeholder="نام کاربری خود را وارد کنید" />
          </div>
          <span asp-validation-for="Username" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group">
          <label asp-for="Email"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="m2 7 10 7 10-7" stroke="currentColor" stroke-width="1.4"/></svg></span>
            <input asp-for="Email" class="form-input" placeholder="ایمیل خود را وارد کنید" />
          </div>
          <span asp-validation-for="Email" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group">
          <label asp-for="PhoneNumber"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="7" y="2" width="10" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <input asp-for="PhoneNumber" class="form-input" placeholder="شماره موبایل خود را وارد کنید" />
          </div>
          <span asp-validation-for="PhoneNumber" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group">
          <label asp-for="Password"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <div class="input-password-wrap">
              <input asp-for="Password" class="form-input" placeholder="رمز عبور خود را وارد کنید" style="padding-left:40px" />
              <button type="button" class="pwd-toggle"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/></svg></button>
            </div>
          </div>
          <span asp-validation-for="Password" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group">
          <label asp-for="ConfirmPassword"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <div class="input-password-wrap">
              <input asp-for="ConfirmPassword" class="form-input" placeholder="رمز عبور را تکرار کنید" style="padding-left:40px" />
              <button type="button" class="pwd-toggle"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/></svg></button>
            </div>
          </div>
          <span asp-validation-for="ConfirmPassword" style="color:#e1452f;font-size:12px"></span>
        </div>

        <button type="submit" class="btn-auth" style="margin-top:8px;margin-bottom:16px">ثبت‌نام</button>
      </form>

      <div class="auth-no-account" style="margin-top:20px">
        <div><p>قبلاً ثبت‌نام کرده‌اید؟</p><small>وارد حساب کاربری خود شوید.</small></div>
        <a href="/Account/Login" class="btn-cta" style="white-space:nowrap">ورود به حساب</a>
      </div>
    </div>
  </div>

  <div class="auth-hero-panel reveal-from-left">
    <div class="auth-hero-features">
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مدیریت سفارش‌ها</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M2 3h2l2.4 12.2a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.6L21 7H6" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="20" r="1.3" fill="currentColor"/><circle cx="17" cy="20" r="1.3" fill="currentColor"/></svg></div>سفارش کالا از فروشگاه‌های مرجع</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 13.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" stroke="currentColor" stroke-width="1.5"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مدیریت آدرس‌ها</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M7 3.5h7l4 4V20a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4.5a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مشاهده سوابق خرید</div>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
