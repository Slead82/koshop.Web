@model LoginViewModel
@{
    ViewData["Title"] = "ورود به حساب کاربری";
    ViewData["ActiveNav"] = "";
}

<div class="shop-page-header">
  <div class="shop-page-header-inner">
    <div class="breadcrumb reveal-from-right">
      <a href="/">صفحه اصلی</a><span class="crumb-sep">›</span><span style="color:var(--orange)">ورود</span>
    </div>
  </div>
</div>

<div class="auth-page-layout">
  <div class="auth-form-panel reveal-from-right">
    <div class="auth-form-box">
      <h1 class="auth-title">ورود به حساب کاربری</h1>
      <div class="auth-title-line"></div>
      <p class="auth-sub">برای مدیریت سفارش‌ها و استفاده از خدمات KO وارد حساب کاربری خود شوید.</p>

      <form asp-controller="Account" asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <div asp-validation-summary="ModelOnly" class="auth-validation-summary" style="color:#e1452f;font-size:13px;margin-bottom:12px"></div>

        <div class="form-group" style="margin-bottom:16px">
          <label asp-for="UsernameOrEmailOrPhone"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.6" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
            <input asp-for="UsernameOrEmailOrPhone" class="form-input" placeholder="شماره موبایل، ایمیل یا نام کاربری خود را وارد کنید" />
          </div>
          <span asp-validation-for="UsernameOrEmailOrPhone" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="form-group" style="margin-bottom:12px">
          <label asp-for="Password"></label>
          <div class="form-input-icon">
            <span class="fi-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.5"/></svg></span>
            <div class="input-password-wrap">
              <input asp-for="Password" class="form-input" placeholder="رمز عبور خود را وارد کنید" style="padding-left:40px" />
              <button type="button" class="pwd-toggle"><svg viewBox="0 0 24 24" fill="none" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/></svg></button>
            </div>
          </div>
          <span asp-validation-for="Password" style="color:#e1452f;font-size:12px"></span>
        </div>

        <div class="auth-footer-row">
          <label class="auth-check-row"><input asp-for="RememberMe" /> مرا به خاطر بسپار</label>
          <a href="/Account/ForgotPassword" class="auth-link">رمز عبور خود را فراموش کردید؟</a>
        </div>

        <button type="submit" class="btn-auth" style="margin-top:16px;margin-bottom:16px">ورود به حساب کاربری</button>
      </form>

      <div class="auth-no-account" style="margin-top:20px">
        <div><p>حساب کاربری ندارید؟</p><small>با ثبت‌نام در KO از خدمات ویژه و تجربه خرید آسان لذت ببرید.</small></div>
        <a href="/Account/Register" class="btn-cta" style="white-space:nowrap">ثبت‌نام در KO</a>
      </div>

      <div style="text-align:center;margin-top:18px">
        <a href="/AdminAccount/Login" style="font-size:12px;color:var(--ink-soft);display:inline-flex;align-items:center;gap:6px">
          <svg viewBox="0 0 24 24" fill="none" width="14" height="14"><rect x="4" y="10" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V7a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.5"/></svg>
          ورود مدیران سیستم
        </a>
      </div>
    </div>
  </div>

  <div class="auth-hero-panel reveal-from-left">
    <div class="auth-hero-features">
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مدیریت سفارش‌ها</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M2 3h2l2.4 12.2a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.6L21 7H6" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="20" r="1.3" fill="currentColor"/><circle cx="17" cy="20" r="1.3" fill="currentColor"/></svg></div>سفارش کالا از فروشگاه‌های مرجع</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 13.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" stroke="currentColor" stroke-width="1.5"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مدیریت آدرس‌ها</div>
      <div class="ahf-row"><div class="ahf-icon"><svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M7 3.5h7l4 4V20a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4.5a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.5"/></svg></div>مشاهده سوابق خرید</div>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
